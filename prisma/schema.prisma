generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Regalo {
  id            Int           @id @default(autoincrement())
  nombre        String
  mensaje       String
  moneda        String        // "BOB" o "USD"
  monto         Float?
  verificado    Boolean       @default(false)
  eliminado     Boolean       @default(false)
  fechaCreacion DateTime      @default(now())
  fechaVerificacion DateTime?
  opcionId      Int?
  opcion        OpcionRegalo? @relation(fields: [opcionId], references: [id])
}

model OpcionRegalo {
  id          Int      @id @default(autoincrement())
  nombre      String
  emoji       String
  tipo        String   // "abrazo" o "torta"
  descripcion String
  montoBOB    Float?
  montoUSD    Float?
  qrUrl       String?
  qrPublicId  String?
  pagoUrl     String?
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  regalos     Regalo[]
}

model Foto {
  id        Int      @id @default(autoincrement())
  url       String
  publicId  String?
  titulo    String?
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}